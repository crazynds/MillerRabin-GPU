// Sliding-window size for modular exponentiation (base^exp mod N).
// Controls the power-table size: 2^MR_WINDOW_BITS entries per candidate.
// Larger = fewer squarings but more VRAM for the table. Range: 4–10.
#define MR_WINDOW_BITS @MR_WINDOW_BITS@

// Number of candidates processed in a single GPU kernel launch.
// All candidates in a batch must share the same n_limbs.
// Larger = better GPU utilization but higher peak VRAM usage.
#define MR_BATCH_SIZE @MR_BATCH_SIZE@

// Base of the big-integer limb representation: each limb is a digit in base 2^LIMB_BITS.
// Smaller → more limbs (slower) but more precision headroom for FFT/NTT backends.
// Larger → fewer limbs (faster) but product coefficients grow faster, risking overflow.
// Runtime guards in each multiplication backend validate safety for the chosen size.
// Sane range: 4–30.
#define LIMB_BITS @LIMB_BITS@
#if (LIMB_BITS) < 4 || (LIMB_BITS) > 30
#error "LIMB_BITS out of the sane range [4,30] (params.cmake). Above ~30 overflows the carry/product accumulators."
#endif

/** --------------------------------------------------
                    Threads per block
         All must be a multiple of 32 (warp size).
------------------------------------------------------*/

#define MR_THR_LOAD @MR_THR_LOAD@
#define MR_THR_PMUL @MR_THR_PMUL@
#define MR_THR_ADD @MR_THR_ADD@
#define MR_THR_SELECT_WIN @MR_THR_SELECT_WIN@
#define MR_THR_CHECK @MR_THR_CHECK@
#define MR_THR_COPY @MR_THR_COPY@
#define MR_CARRY_INTER_THR @MR_CARRY_INTER_THR@

/** --------------------------------------------------
             Carry normalization — available algorithms

  CARRY_ALG_SINGLE_TILE — 1 block per candidate, MR_CARRY_TILE threads.
    All tiles of a candidate are processed by a single block using
    shared-memory carry propagation between tiles.
    Lower GPU occupancy but no inter-block synchronization needed.

  CARRY_ALG_MULTI_TILE  — 2 separate kernel launches:
    Phase 1 (intra): n_tiles × n_batch blocks in parallel; each block
      normalizes MR_CARRY_TILE limbs and writes its output carry to d_tile_carry.
    Phase 2 (inter): 1 thread per candidate propagates the tile carries
      sequentially. Higher occupancy in phase 1 than SINGLE_TILE.

  CARRY_ALG_SEQUENTIAL  — 1 thread per candidate iterates over all limbs
    sequentially. Minimal shared memory; useful as a correctness baseline
    or when the tile algorithms exhibit race conditions.

  CARRY_ALG_PREFIX_SCAN — parallel prefix-scan over all limbs in one pass.
    Highest theoretical occupancy; experimental.

------------------------------------------------------*/

#define CARRY_NORM_ALG @CARRY_NORM_ALG@

// Threads per block (tile width) for the SINGLE_TILE and MULTI_TILE carry kernels.
// Each thread handles one limb; must be a multiple of 32.
#define MR_CARRY_TILE @MR_CARRY_TILE@

/** --------------------------------------------------
              Conditional subtraction (cond_sub)
------------------------------------------------------*/

// Tile width for cond_sub_batch (cs_phase1 + cs_apply kernels).
// cs_phase1 scans MR_SUB_TILE limbs per block to determine the borrow chain;
// cs_apply uses the same tile to write the corrected output.
#define MR_SUB_TILE @MR_SUB_TILE@

