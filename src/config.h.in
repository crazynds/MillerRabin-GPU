                       Monitoring
------------------------------------------------------*/

// Minimum wall-clock interval between progress-bar screen updates (milliseconds).
// Smaller = more frequent updates at the cost of minor printf overhead.
#define MR_PROGRESS_INTERVAL_MS @MR_PROGRESS_INTERVAL_MS@

// When defined, the monitor also prints per-batch carry normalization statistics
// (min/max/avg iterations). Useful for tuning CARRY_NORM_ALG; adds measurable overhead.
#cmakedefine MR_ADVANCED_MONITOR

// When defined, the pointwise NTT-domain multiply/square is fused into the
// first INTT kernel, saving one full global-memory round-trip per multiplication.
// Only active for MUL_NTT_MERGE backend.
#cmakedefine MR_NTT_FUSED_PMUL

